# Server
PORT=3000
NODE_ENV=development

# Database — pilih salah satu (mysql atau postgresql)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_absensi
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=ganti_dengan_secret_key_yang_panjang_dan_random
JWT_EXPIRES_IN=8h

# Storage (local atau cloudinary)
STORAGE_TYPE=local
UPLOAD_PATH=./uploads

# Cloudinary (jika STORAGE_TYPE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase (untuk push notification)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://dashboard.perusahaan.com